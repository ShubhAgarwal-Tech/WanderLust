<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="WanderLust — discover unique stays and experiences worldwide." />
    <title>WanderLust | Find your next adventure</title>
    <script src="/js/theme.js"></script>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      crossorigin="anonymous"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/style.css" />
    <link href="/css/rating.css" rel="stylesheet" />
    <link href="/css/pages/home.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
  </head>
  <body
    class="<%= typeof pageClass !== 'undefined' ? pageClass : '' %>"
    data-logged-in="<%= currUser ? 'true' : 'false' %>"
  >
    <%- include("../includes/navbar.ejs") %>
    <main class="main-content" id="main-content">
      <div class="wl-flash-wrap" aria-live="polite">
        <%- include("../includes/flash.ejs") %>
      </div>
      <% if (typeof fullWidth !== 'undefined' && fullWidth) { %>
      <div class="container-fluid-layout"><%- body %></div>
      <% } else { %>
      <div class="container-layout"><%- body %></div>
      <% } %>
    </main>
    <%- include("../includes/footer.ejs") %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script src="/js/toast.js"></script>
    <script src="/js/images.js" defer></script>
    <script src="/js/script.js"></script>
    <script src="/js/favorites.js" defer></script>
    <script src="/js/app.js" defer></script>
    <script src="/js/listings-page.js" defer></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script src="/js/map.js" defer></script>
    <script src="/js/booking.js" defer></script>
  </body>
</html>
