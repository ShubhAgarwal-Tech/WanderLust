<% layout("/layouts/boilerplate")%>
<div class="row justify-content-center mt-3 mb-5">
  <div class="col-lg-8 col-xl-7">
    <h1 class="h3 fw-bold mb-4">Edit your listing</h1>
    <form
      action="/listings/<%=listing._id%>?_method=put"
      method="post"
      novalidate
      class="needs-validation wl-panel rounded-4 p-3 p-md-4"
      enctype="multipart/form-data"
    >
      <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input
          type="text"
          name="listing[title]"
          value="<%=listing.title%>"
          class="form-control"
          required
        />
        <div class="valid-feedback">Title looks good!</div>
      </div>
      <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea name="listing[description]" class="form-control" required>
<%=listing.description%></textarea
        >
        <div class="invalid-feedback">Please enter a short description</div>
      </div>

      <div class="mb-3">
        <label for="category" class="form-label">Category</label>
        <select name="listing[category]" id="category" class="form-select" required>
          <% (categories || []).forEach((cat) => { %>
          <option value="<%= cat.id %>" <%= listing.category === cat.id ? "selected" : "" %>><%= cat.label %></option>
          <% }) %>
        </select>
        <div class="invalid-feedback">Please select a category</div>
      </div>

      <div class="mb-3">
        <label for="propertyType" class="form-label">Property type</label>
        <select name="listing[propertyType]" id="propertyType" class="form-select">
          <% (propertyTypes || []).forEach((pt) => { %>
          <option value="<%= pt %>" <%= listing.propertyType === pt ? "selected" : "" %>><%= pt %></option>
          <% }) %>
        </select>
      </div>

      <div class="mb-3">
        <label for="maxGuests" class="form-label">Max guests</label>
        <input type="number" name="listing[maxGuests]" id="maxGuests" class="form-control" min="1" max="16" value="<%= listing.maxGuests || 2 %>" required />
      </div>

      <div class="mb-3">
        <label class="form-label">Amenities</label>
        <div class="row row-cols-1 row-cols-sm-2 g-2">
          <% const selectedAmenities = listing.amenities || []; %>
          <% (amenitiesList || []).forEach((am) => { %>
          <div class="col">
            <div class="form-check">
              <input class="form-check-input" type="checkbox" name="listing[amenities]" value="<%= am %>" id="edit-am-<%= am.replace(/\s/g,'') %>" <%= selectedAmenities.includes(am) ? "checked" : "" %> />
              <label class="form-check-label" for="edit-am-<%= am.replace(/\s/g,'') %>"><%= am %></label>
            </div>
          </div>
          <% }) %>
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label">Current cover image</label>
        <div class="wl-img-wrap wl-media-4x3 wl-edit-cover">
          <img src="<%=originalimageUrl%>" alt="<%= listing.title %>" class="wl-img w-100 h-100 wl-object-cover" data-category="<%= listing.category %>" />
          <span class="wl-img-skeleton" aria-hidden="true"></span>
        </div>
      </div>

      <div class="mb-3">
        <label for="image" class="form-label">Upload New Cover Image</label>
        <input name="listing[image]" id="image" type="file" class="form-control" />
      </div>
      <div class="mb-3">
        <label for="images" class="form-label">Add More Images (hotel/rooms/etc)</label>
        <input
          name="listing[images]"
          id="images"
          type="file"
          class="form-control"
          multiple
          accept="image/*"
        />
      </div>
      <div class="mb-3">
        <label for="price" class="form-label">Price</label>
        <input
          name="listing[price]"
          value="<%=listing.price%>"
          type="number"
          min="0"
          step="1"
          class="form-control"
          required
        />
        <div class="invalid-feedback">Price should be valid</div>
      </div>
      <div class="mb-3">
        <label for="country" class="form-label">Country</label>
        <input
          type="text"
          name="listing[country]"
          value="<%=listing.country%>"
          class="form-control"
          required
        />
        <div class="invalid-feedback">Country name should be valid</div>
      </div>
      <div class="mb-3">
        <label for="location" class="form-label">Location</label>
        <input
          type="text"
          name="listing[location]"
          value="<%=listing.location%>"
          class="form-control"
          required
        />
        <div class="invalid-feedback">Location should be valid</div>
      </div>
      <button class="wl-btn wl-btn--primary edit-btn mt-3">Save changes</button>
    </form>
  </div>
</div>
