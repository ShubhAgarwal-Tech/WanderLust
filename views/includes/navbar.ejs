<header class="wl-navbar" id="wl-navbar" role="banner">
  <div class="wl-container wl-navbar__inner">
    <a class="wl-navbar__brand" href="/" aria-label="WanderLust home">
      <i class="fa-solid fa-compass" aria-hidden="true"></i>
      <span>WanderLust</span>
    </a>

    <form class="wl-navbar__search" action="/listings" method="GET" role="search">
      <div class="wl-search-pill">
        <input
          type="search"
          name="q"
          placeholder="Search destinations"
          aria-label="Search destinations"
          value="<%= typeof q !== 'undefined' ? q : '' %>"
          autocomplete="off"
        />
        <button type="submit" aria-label="Search">
          <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
        </button>
      </div>
    </form>

    <div class="wl-navbar__actions">
      <button type="button" class="wl-nav-icon" data-theme-toggle aria-label="Toggle theme">
        <i class="fa-solid fa-moon" aria-hidden="true"></i>
      </button>
      <a href="/listings" class="d-none d-md-inline wl-btn wl-btn--ghost wl-btn--sm">Explore</a>

      <% if (currUser) { %>
      <a href="/favorites" class="wl-nav-icon" aria-label="Wishlist" title="Wishlist">
        <i class="fa-regular fa-heart" aria-hidden="true"></i>
      </a>
      <a href="/bookings" class="wl-nav-icon d-none d-md-grid" aria-label="Bookings" title="Bookings">
        <i class="fa-regular fa-calendar" aria-hidden="true"></i>
      </a>
      <% } else { %>
      <a href="/login" class="wl-nav-icon" aria-label="Wishlist" title="Sign in to save favorites">
        <i class="fa-regular fa-heart" aria-hidden="true"></i>
      </a>
      <% } %>

      <button
        type="button"
        class="wl-nav-menu-btn"
        id="wl-nav-toggle"
        aria-haspopup="true"
        aria-expanded="false"
        aria-controls="wl-mobile-nav"
        aria-label="Open menu"
      >
        <i class="fa-solid fa-bars" aria-hidden="true"></i>
        <i class="fa-regular fa-circle-user" aria-hidden="true"></i>
      </button>
    </div>
  </div>

  <nav class="wl-mobile-nav" id="wl-mobile-nav" aria-label="Account navigation">
    <form action="/listings" method="GET" class="mb-3 d-md-none">
      <div class="wl-search-pill">
        <input type="search" name="q" placeholder="Search" aria-label="Search" />
        <button type="submit" aria-label="Search"><i class="fa-solid fa-magnifying-glass"></i></button>
      </div>
    </form>
    <a href="/">Home</a>
    <a href="/listings">Explore stays</a>
    <% if (currUser) { %>
    <a href="/listings/new">Host your home</a>
    <a href="/favorites">Wishlist</a>
    <a href="/bookings">My bookings</a>
    <a href="/logout">Log out</a>
    <% } else { %>
    <a href="/signup">Sign up</a>
    <a href="/login">Log in</a>
    <% } %>
  </nav>
</header>
