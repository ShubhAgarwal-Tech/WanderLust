<% layout("/layouts/boilerplate")%>

<div class="row justify-content-center mt-4 mb-5">
  <div class="col-12 col-md-6 col-lg-5">
    <div class="wl-panel rounded-4 p-4 p-md-5 shadow-sm">
      <h1 class="h3 fw-bold mb-1">Join WanderLust</h1>
      <p class="text-muted mb-4">Create an account to book, host, and save favorites.</p>
      <form action="/signup" method="post" class="needs-validation" novalidate>
        <div class="mb-3">
          <label for="username" class="form-label">Username</label>
          <input type="text" name="username" class="wl-input" id="username" required />
        </div>
        <div class="mb-3">
          <label for="email" class="form-label">Email</label>
          <input type="email" name="email" class="wl-input" id="email" required />
        </div>
        <div class="mb-4">
          <label for="password" class="form-label">Password</label>
          <input type="password" name="password" class="wl-input" id="password" required />
        </div>
        <button class="wl-btn wl-btn--primary w-100">Sign up</button>
      </form>
      <p class="text-center text-muted small mt-3 mb-0">
        Already have an account? <a href="/login">Log in</a>
      </p>
    </div>
  </div>
</div>
