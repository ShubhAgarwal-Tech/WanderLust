<% layout("/layouts/boilerplate") %>

<div class="mt-3 mb-5">
  <h1 class="h3 fw-bold mb-4">My bookings</h1>

  <% if (!bookings || bookings.length === 0) { %>
  <div class="wl-empty is-visible">
    <div class="wl-empty__icon"><i class="fa-regular fa-calendar"></i></div>
    <h3>No bookings yet</h3>
    <p>When you reserve a stay, it will appear here.</p>
    <a href="/listings" class="wl-btn wl-btn--primary">Explore stays</a>
  </div>
  <% } else { %>
  <div class="row g-3">
    <% bookings.forEach((booking) => { %>
    <% if (booking.listing) { %>
    <div class="col-12">
      <article class="booking-list-card p-3 p-md-4 d-flex flex-column flex-md-row gap-3 align-items-md-center">
        <div class="wl-img-wrap wl-media-4x3 booking-list-card__media flex-shrink-0">
          <img
            src="<%= booking.listing.image?.url %>"
            alt="<%= booking.listing.title %>"
            class="wl-img w-100 h-100 wl-object-cover"
            loading="lazy"
            decoding="async"
            data-title="<%= booking.listing.title %>"
            data-category="<%= booking.listing.category || 'Trending' %>"
          />
          <span class="wl-img-skeleton" aria-hidden="true"></span>
        </div>
        <div class="flex-grow-1">
          <h2 class="h6 fw-bold mb-1"><%= booking.listing.title %></h2>
          <p class="text-muted small mb-1">
            <%= new Date(booking.checkIn).toLocaleDateString() %> – <%= new Date(booking.checkOut).toLocaleDateString() %>
            · <%= booking.guests %> guests
          </p>
          <span class="wl-badge <%= booking.status === 'confirmed' ? '' : 'text-bg-warning' %>">
            <%= booking.status %> · <%= booking.paymentStatus %>
          </span>
        </div>
        <div class="booking-list-card__aside text-md-end">
          <p class="fw-bold mb-2">₹<%= booking.totalAmount?.toLocaleString('en-IN') || '—' %></p>
          <div class="wl-mobile-actions justify-content-md-end">
            <a href="/bookings/<%= booking._id %>" class="wl-btn wl-btn--ghost wl-btn--sm">Details</a>
            <% if (booking.status !== 'cancelled') { %>
            <form action="/bookings/<%= booking._id %>?_method=DELETE" method="post" onsubmit="return confirm('Cancel this booking?')">
              <button class="wl-btn wl-btn--ghost wl-btn--sm">Cancel</button>
            </form>
            <% } %>
          </div>
        </div>
      </article>
    </div>
    <% } %>
    <% }) %>
  </div>
  <% } %>
</div>
