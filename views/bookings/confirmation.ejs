<% layout("/layouts/boilerplate") %>

<div class="text-center py-5 wl-reveal is-visible">
  <div class="wl-empty__icon wl-success-icon mx-auto mb-3">
    <i class="fa-solid fa-check"></i>
  </div>
  <h1 class="h3 fw-bold">You're going to <%= booking.listing.location %>!</h1>
  <p class="text-muted">Confirmation #<%= String(booking._id).slice(-8).toUpperCase() %></p>
  <div class="border rounded-4 p-3 p-sm-4 text-start wl-max-480 mx-auto mt-4">
    <p class="mb-1"><strong><%= booking.listing.title %></strong></p>
    <p class="text-muted small mb-2">
      <%= new Date(booking.checkIn).toLocaleDateString() %> – <%= new Date(booking.checkOut).toLocaleDateString() %>
      · <%= booking.guests %> guests
    </p>
    <p class="mb-0 fw-semibold">Total paid: ₹<%= booking.totalAmount.toLocaleString('en-IN') %></p>
  </div>
  <div class="d-flex gap-2 justify-content-center mt-4 flex-wrap">
    <a href="/bookings" class="wl-btn wl-btn--primary">My bookings</a>
    <a href="/listings/<%= booking.listing._id %>" class="wl-btn wl-btn--ghost">View listing</a>
  </div>
</div>
